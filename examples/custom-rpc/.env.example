# Put your preferred providers in priority-independent order.
# Sendra chooses by health and measured latency, not by list position.
SENDRA_DEVNET_URL_1=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SENDRA_DEVNET_URL_2=https://your-devnet-endpoint.quiknode.pro/YOUR_TOKEN
SENDRA_DEVNET_URL_3=https://api.devnet.solana.com

RECIPIENT_PUBLIC_KEY=11111111111111111111111111111111
TRANSFER_SOL=0.001
SENDER_SECRET_KEY=[1,2,3,4]
# SENDER_KEYPAIR_PATH=/Users/alice/.config/solana/id.json
MAX_RETRIES=3
