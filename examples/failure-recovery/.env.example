# The first endpoint is intentionally unreachable to demonstrate health filtering.
SENDRA_DEVNET_URL_1=http://127.0.0.1:8899
SENDRA_DEVNET_URL_2=https://api.devnet.solana.com
# SENDRA_DEVNET_URL_3=https://your-devnet-provider.example

RECIPIENT_PUBLIC_KEY=11111111111111111111111111111111
TRANSFER_SOL=0.001
SENDER_SECRET_KEY=[1,2,3,4]
# SENDER_KEYPAIR_PATH=/Users/alice/.config/solana/id.json

MAX_RETRIES=4
