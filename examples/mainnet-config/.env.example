# Mainnet RPC pool. Use your real provider URLs.
SENDRA_MAINNET_URL_1=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SENDRA_MAINNET_URL_2=https://your-quicknode-endpoint.quiknode.pro/YOUR_TOKEN
SENDRA_MAINNET_URL_3=https://api.mainnet-beta.solana.com

# Safety gate. Leave false while validating config.
CONFIRM_MAINNET_SEND=false

RECIPIENT_PUBLIC_KEY=11111111111111111111111111111111
TRANSFER_SOL=0.000001
SENDER_SECRET_KEY=[1,2,3,4]
# SENDER_KEYPAIR_PATH=/Users/alice/.config/solana/mainnet.json

MAX_RETRIES=5
NETWORK=mainnet
