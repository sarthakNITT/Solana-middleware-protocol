{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": "..",
    "paths": {
      "sendra-tx": ["packages/sdk/src/types.d.ts"],
      "@repo/types": ["packages/types/src/index.ts"]
    },
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["*/src/**/*.ts"]
}
