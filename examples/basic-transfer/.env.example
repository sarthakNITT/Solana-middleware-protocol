# Devnet is the safest first run. Add more URLs to let Sendra route and fail over.
SENDRA_DEVNET_URL_1=https://api.devnet.solana.com
# SENDRA_DEVNET_URL_2=https://your-devnet-provider.example

# Recipient public key.
RECIPIENT_PUBLIC_KEY=11111111111111111111111111111111

# Small devnet transfer amount.
TRANSFER_SOL=0.001

# Use either SENDER_SECRET_KEY or SENDER_KEYPAIR_PATH.
SENDER_SECRET_KEY=[1,2,3,4]
# SENDER_KEYPAIR_PATH=/Users/alice/.config/solana/id.json

MAX_RETRIES=3
