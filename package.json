{
  "name": "solana-middleware-protocol",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-examples": "tsc -p examples/tsconfig.json --noEmit",
    "test": "turbo run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "turbo run test -- --run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
