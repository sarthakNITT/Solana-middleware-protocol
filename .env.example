# Sendra Environment Configuration
# Copy this file to .env and fill in the values

# --- Solana RPC Configuration ---
# Provide multiple RPCs for failover and health monitoring (comma-separated)
NEXT_PUBLIC_SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com,https://solana-mainnet.g.alchemy.com/v2/YOUR_API_KEY,https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# --- Dashboard & Web Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# --- Logging & Analytics ---
# Enable persistent file logging (true/false)
SENDRA_ENABLE_FILE_LOGS=true
# Directory for log storage (default: ./sendra-logs)
SENDRA_LOG_DIR=./sendra-logs
# Log level: debug, info, warn, error
SENDRA_LOG_LEVEL=info

# --- API & Orchestration ---
# Secret for internal API authentication
SENDRA_API_SECRET=your_super_secret_api_key
# Database URL if using persistent storage for transaction history
# DATABASE_URL=postgresql://user:password@localhost:5432/sendra

# --- Monitoring ---
# Optional: Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn

# --- Branding & Customization ---
NEXT_PUBLIC_SITE_NAME=Sendra Dashboard
NEXT_PUBLIC_SITE_DESCRIPTION=Solana Transaction Reliability Layer
